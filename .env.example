LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
OPENAI_API_KEY=<your OpenAI API Key>
DEEPGRAM_API_KEY=<your Deepgram API Key>
SIP_OUTBOUND_TRUNK_ID=<your SIP Outbound Trunk ID>

# Voice (TTS) provider. Deepgram always handles speech-to-text.
#   60db   -> 60db.ai WebSocket TTS (default)
#   openai -> OpenAI TTS (fallback)
TTS_PROVIDER=60db

# Required when TTS_PROVIDER=60db
SIXTYDB_API_KEY=<your 60db API Key>
SIXTYDB_VOICE_ID=<a voice_id from GET https://api.60db.ai/myvoices>

# Optional 60db TTS overrides (sensible defaults are used if unset)
# SIXTYDB_WS_URL=wss://api.60db.ai/ws/tts
# SIXTYDB_TTS_ENCODING=LINEAR16   # or MULAW
# SIXTYDB_TTS_SAMPLE_RATE=8000
